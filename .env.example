# --- CONFIGURAÇÕES DO INVITE-APP (SaaS) ---

# App Config
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- SUPABASE (Banco, Auth e Operações Privilegiadas) ---
# Encontre em: Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://sua-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-jwt
# Chave Service Role é usada no Webhook da Stripe para bypass no RLS. Mantenha em segredo absoluto.
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role

# Database (Obrigatório apenas para rodar scripts de migração/TDD no CLI)
# Formato: postgresql://postgres:[SENHA]@[HOST]:5432/postgres
DATABASE_URL=postgresql://postgres:sua-senha@db.sua-url.supabase.co:5432/postgres

# --- MONETIZAÇÃO (Stripe) ---
# Encontre em: Dashboard do Stripe -> Developers -> API keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Encontre webhook secret em: Developers -> Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# --- MÍDIA (Cloudinary) ---
# Obrigatório para fotos dos presentes e Galeria do Evento
# Encontre em: Dashboard do Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=seu-cloud-name
CLOUDINARY_API_KEY=sua-api-key
CLOUDINARY_API_SECRET=sua-api-secret

# --- SEGURANÇA E AUTH ---
# ADMIN_PASSWORD= (Removido na STORY-039. Faça login via Supabase Magic Link ou Email/Senha)
